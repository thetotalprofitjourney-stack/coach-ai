// Coach AI — data model (paso 1).
// Referencia: docs/proyecto-completo.md §3.3.
// Todas las tablas están vinculadas a `sessions` por session_id y se borran en
// cascada. Esto es crítico para el cron nocturno de borrado (hard delete).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  created
  phase1_in_progress
  phase1_completed
  phase2_in_progress
  phase2_completed
  closed
}

enum TurnRole {
  coach
  user
}

model Session {
  id                     String        @id @default(uuid()) @db.Uuid
  status                 SessionStatus @default(created)
  createdAt              DateTime      @default(now()) @map("created_at")
  closedAt               DateTime?     @map("closed_at")
  // Los campos del formulario inicial (§2.3) se rellenan en la transición
  // `created` → `phase1_in_progress` vía POST /api/session/{token}/form.
  // Nullable porque en el estado `created` la sesión ya existe (la creó el
  // webhook de Stripe) pero aún no hay datos de usuario.
  userName               String?       @map("user_name")
  userAge                Int?          @map("user_age")
  userFamilyContext      String?       @map("user_family_context")
  userLocation           String?       @map("user_location")
  userProfessionalMoment String?       @map("user_professional_moment")
  userTrigger            String?       @map("user_trigger")

  phase1Responses Phase1Response[]
  phase1Handoff   Phase1Handoff?
  phase2Turns     Phase2Turn[]
  phase2State     Phase2State?
  finalReport     FinalReport?
  llmCalls        LlmCall[]

  @@index([status, createdAt])
  @@index([closedAt])
  // Recolector de métricas diarias (§7.3, Paso 14): particiona por
  // DATE(created_at) y filtra por status. El índice existente lidera
  // por status, útil para el cleanup; éste lidera por created_at y
  // sirve rangos diarios sobre la tabla completa.
  @@index([createdAt, status], map: "idx_sessions_created_status")
  @@map("sessions")
}

model Phase1Response {
  id               String   @id @default(uuid()) @db.Uuid
  sessionId        String   @map("session_id") @db.Uuid
  itemNumber       Int      @map("item_number")
  itemContent      Json     @map("item_content") @db.JsonB
  chosenOption     String?  @map("chosen_option") @db.Char(1)
  secondaryOptions String[] @map("secondary_options") @db.Char(1)
  freeText         String?  @map("free_text")
  createdAt        DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, itemNumber])
  @@index([sessionId])
  @@map("phase1_responses")
}

model Phase1Handoff {
  sessionId      String   @id @map("session_id") @db.Uuid
  handoffContent Json     @map("handoff_content") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("phase1_handoff")
}

model Phase2Turn {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  turnNumber Int      @map("turn_number")
  role       TurnRole
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, turnNumber])
  @@index([sessionId])
  @@map("phase2_turns")
}

model Phase2State {
  sessionId                String   @id @map("session_id") @db.Uuid
  currentLevel             Int      @default(1) @map("current_level")
  hypothesesExplored       String[] @default([]) @map("hypotheses_explored")
  runningSummary           String   @default("") @map("running_summary")
  // Términos subjetivos del hand-off ya desambiguados durante Fase 2.
  // El auxiliar (§4.3) los va acumulando turno a turno. Derivar pending
  // desde `handoff.terminos_subjetivos` - resolved no es suficiente porque
  // el usuario puede introducir términos nuevos durante la conversación,
  // por eso también persistimos `subjectiveTermsPending`.
  subjectiveTermsResolved  String[] @default([]) @map("subjective_terms_resolved")
  subjectiveTermsPending   String[] @default([]) @map("subjective_terms_pending")
  updatedAt                DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("phase2_state")
}

// Métricas agregadas sin PII (§7.3, Paso 14). Poblada por el cron
// nocturno antes del borrado, persiste contadores por día (UTC) para
// responder a preguntas operativas más allá del TTL 24-48h de las
// sesiones. Sin FK a `sessions`: las sesiones ya están borradas
// cuando estas filas se consolidan.
//
// Las 8 columnas `total*` / `avg*` / `avgLatency*` las añade el Paso
// 15 (coste de API por sesión y latencia, §7.3). Todas nullable
// porque un día sin tráfico productivo no tiene valores.
model DailyStats {
  date                          DateTime @id @db.Date
  sessionsCreated               Int      @default(0) @map("sessions_created")
  sessionsFormSubmitted         Int      @default(0) @map("sessions_form_submitted")
  sessionsPhase1Completed       Int      @default(0) @map("sessions_phase1_completed")
  sessionsPhase2Completed       Int      @default(0) @map("sessions_phase2_completed")
  sessionsClosed                Int      @default(0) @map("sessions_closed")
  sessionsAbandoned             Int      @default(0) @map("sessions_abandoned")
  reportsDownloaded             Int      @default(0) @map("reports_downloaded")
  avgPhase2Turns                Float?   @map("avg_phase2_turns")
  avgDurationSeconds            Float?   @map("avg_duration_seconds")
  p50DurationSeconds            Int?     @map("p50_duration_seconds")
  p95DurationSeconds            Int?     @map("p95_duration_seconds")
  // BigInt en tokens: un día muy cargado (1000 sesiones × cache write
  // del coach) ya supera los 2^31. Suma lineal sobre llm_calls del día.
  totalInputTokens              BigInt?  @map("total_input_tokens")
  totalOutputTokens             BigInt?  @map("total_output_tokens")
  totalCacheCreationTokens      BigInt?  @map("total_cache_creation_tokens")
  totalCacheReadTokens          BigInt?  @map("total_cache_read_tokens")
  totalCostUsd                  Float?   @map("total_cost_usd")
  avgCostUsdPerCompletedSession Float?   @map("avg_cost_usd_per_completed_session")
  avgLatencyMsHaiku             Int?     @map("avg_latency_ms_haiku")
  avgLatencyMsSonnet            Int?     @map("avg_latency_ms_sonnet")
  avgLatencyMsOpus              Int?     @map("avg_latency_ms_opus")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  @@map("daily_stats")
}

// Registro por llamada a la API de Anthropic en rutas productivas
// (§7.3, Paso 15). Transitoria: poblada durante el uso normal, agregada
// por `collectDailyStats` y borrada en cascada con las sesiones por el
// cron nocturno. Consistente con §6.4: los datos concretos por sesión
// desaparecen; sólo sobreviven los agregados en `daily_stats`.
//
// `model` guarda la etiqueta normalizada corta ("haiku-4-5",
// "sonnet-4-6", "opus-4-7") — el mapping vive en
// `src/lib/anthropic/models.ts` y `src/lib/metrics/pricing.ts`.
model LlmCall {
  id                       String   @id @default(uuid()) @db.Uuid
  sessionId                String   @map("session_id") @db.Uuid
  model                    String
  kind                     String
  inputTokens              Int      @default(0) @map("input_tokens")
  outputTokens             Int      @default(0) @map("output_tokens")
  cacheCreationInputTokens Int      @default(0) @map("cache_creation_input_tokens")
  cacheReadInputTokens     Int      @default(0) @map("cache_read_input_tokens")
  durationMs               Int      @map("duration_ms")
  createdAt                DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("llm_calls")
}

// Sesión de demo gratuita (Fase 2 comprimida, 3 turnos con Haiku) para que
// el visitante pruebe el tono no-directivo antes de pagar. No va unida a
// `sessions` para que el cron la purgue por su propio TTL corto (1h) y no
// viaje por toda la máquina de estados. El historial se guarda como JSON
// porque el ciclo de vida no necesita las garantías de integridad del
// chat real y así evitamos una tabla de turnos más.
model PreviewSession {
  id         String   @id @default(uuid()) @db.Uuid
  // Array de { role: 'coach' | 'user', content: string, turnNumber: int }
  turns      Json     @default("[]")
  turnsUsed  Int      @default(0) @map("turns_used")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("preview_sessions")
}

// Cupo diario por hash de IP para evitar que un mismo visitante queme
// tokens abriendo previews en bucle. El hash se hace con un salt fijo
// del entorno (§6.4: no PII estable); la fila se renueva cada día UTC.
model PreviewQuota {
  ipHash        String   @id @map("ip_hash")
  resetDate     DateTime @db.Date @map("reset_date")
  previewCount  Int      @default(0) @map("preview_count")
  lastPreviewAt DateTime @default(now()) @map("last_preview_at")

  @@index([resetDate])
  @@map("preview_quotas")
}

model FinalReport {
  sessionId     String    @id @map("session_id") @db.Uuid
  reportContent Json      @map("report_content") @db.JsonB
  pdfPath       String?   @map("pdf_path")
  docxPath      String?   @map("docx_path")
  downloadedAt  DateTime? @map("downloaded_at")
  // Marca de envío por email opt-in (§2.4). Se fija cuando el SMTP
  // devuelve 2xx y la dirección del destinatario nunca se persiste:
  // sólo queda esta bandera temporal para impedir reenvíos múltiples.
  // Se borra en cascada con la sesión igual que el resto de campos.
  emailedAt     DateTime? @map("emailed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("final_reports")
}
